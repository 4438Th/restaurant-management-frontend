{
  "name": "restaurant-management-frontend",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:admin": "turbo run dev --filter=admin",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo clean",
    "clean:all": "powershell -Command \"Get-ChildItem -Path . -Include node_modules, .next, dist, .turbo -Recurse -Directory | Remove-Item -Recurse -Force\"",
    "reinstall": "pnpm run clean:all && pnpm install",
    "gen:package": "turbo gen package",
    "gen:feature": "turbo gen feature",
    "create:app": "create next-app@latest"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=20.9.0"
  }
}
